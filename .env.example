# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/invoice_organizer
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me-generate-a-random-64-char-string
ENCRYPTION_KEY=change-me-generate-with-fernet

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/gmail/callback

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# S3 (optional for dev — can use local filesystem)
S3_BUCKET=

# Sentry (optional for dev)
SENTRY_DSN=

# Frontend
FRONTEND_URL=http://localhost:3000
